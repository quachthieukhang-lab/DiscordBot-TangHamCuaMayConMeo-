# Token bot Discord (Discord Developer Portal > Bot)
TOKEN=your_bot_token_here

# Application/Client ID của bot (Discord Developer Portal > General Information)
CLIENT_ID=your_client_id_here

# (Tùy chọn) Guild ID dùng cho deploy commands theo guild — chạy nhanh hơn global
GUILD_ID=

# (Tùy chọn) ID kênh để bot gửi tin nhắn khi khởi động
CHANNEL_ID=

# Discord User ID của owner — bắt buộc cho các lệnh chỉ owner (vd: /addroleall)
OWNER_ID=

# development | production
NODE_ENV=development
