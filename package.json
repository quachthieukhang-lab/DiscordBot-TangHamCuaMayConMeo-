{
  "name": "bot",
  "version": "1.0.0",
  "description": "Discord bot với cấu trúc modular (discord.js v14)",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "deploy": "node deploy-commands.js",
    "export-server": "node export-server.js",
    "lint": "eslint \"src/**/*.js\" deploy-commands.js",
    "lint:fix": "eslint \"src/**/*.js\" deploy-commands.js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\""
  },
  "keywords": [
    "discord",
    "bot",
    "discord.js"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "chalk": "^4.1.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "google-tts-api": "^2.0.2",
    "opusscript": "^0.0.8",
    "youtube-dl-exec": "^3.1.6",
    "youtube-sr": "^4.3.12"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3"
  }
}
